# ═══════════════════════════════════════════════════════════════════════════════
# Coalition LLM - Comprehensive .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ──────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ──────────────────────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/

# ──────────────────────────────────────────────────────────────────────────────
# IDE / Editors
# ──────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# ──────────────────────────────────────────────────────────────────────────────
# Jupyter Notebooks
# ──────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ──────────────────────────────────────────────────────────────────────────────
# Testing / Coverage
# ──────────────────────────────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ──────────────────────────────────────────────────────────────────────────────
# Type checking
# ──────────────────────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ──────────────────────────────────────────────────────────────────────────────
# Data (large files - download via scripts)
# ──────────────────────────────────────────────────────────────────────────────
data/raw/
data/processed/
*.csv
*.json
!configs/**/*.json
*.parquet
*.arrow
*.h5
*.hdf5

# ──────────────────────────────────────────────────────────────────────────────
# Model checkpoints and outputs
# ──────────────────────────────────────────────────────────────────────────────
outputs/
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
wandb/
mlruns/
lightning_logs/

# ──────────────────────────────────────────────────────────────────────────────
# Logs and results
# ──────────────────────────────────────────────────────────────────────────────
logs/
*.log
results/
*.txt
!requirements*.txt
!data/splits/**/*.txt

# ──────────────────────────────────────────────────────────────────────────────
# API keys and secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.json

# ──────────────────────────────────────────────────────────────────────────────
# OS-specific
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ──────────────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────────────
*.docker-compose.override.yml

# ──────────────────────────────────────────────────────────────────────────────
# Hydra outputs
# ──────────────────────────────────────────────────────────────────────────────
multirun/
.hydra/
